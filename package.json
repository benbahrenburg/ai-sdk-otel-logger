{
  "name": "ai-sdk-otel-logger",
  "version": "0.2.0",
  "description": "OpenTelemetry observability plugin for the Vercel AI SDK",
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "bench": "bun run benchmarks/perf.ts",
    "lint": "bunx eslint src/ tests/",
    "format": "bunx prettier --write .",
    "test": "bunx vitest run",
    "test:watch": "bunx vitest",
    "test:coverage": "bunx vitest run --coverage",
    "prepublishOnly": "bun run lint && bunx tsc --noEmit && bun run test:coverage && bun run build"
  },
  "keywords": [
    "ai-sdk",
    "vercel",
    "opentelemetry",
    "otel",
    "observability",
    "telemetry",
    "tracing",
    "logging"
  ],
  "author": "Ben Bahrenburg (https://github.com/benbahrenburg/)",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/benbahrenburg/ai-sdk-otel-logger.git"
  },
  "homepage": "https://github.com/benbahrenburg/ai-sdk-otel-logger",
  "bugs": {
    "url": "https://github.com/benbahrenburg/ai-sdk-otel-logger/issues"
  },
  "peerDependencies": {
    "ai": "^6.0.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-trace-base": "^1.0.0 || ^2.0.0"
  },
  "overrides": {
    "@opentelemetry/api": "$@opentelemetry/api",
    "vite": ">=7.3.2"
  },
  "devDependencies": {
    "@ai-sdk/azure": "^3.0.54",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/sdk-trace-base": "^2.7.0",
    "@opentelemetry/sdk-trace-node": "^2.7.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitest/coverage-v8": "^4.1.4",
    "ai": "^6.0.168",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
